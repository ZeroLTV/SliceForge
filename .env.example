# AI Agent Configuration
# Set agent type: 'cursor-cli' | 'claude-code' | 'api'
SLICEFORGE_AGENT_TYPE=api

# Direct API Credentials (required if SLICEFORGE_AGENT_TYPE=api)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# CLI Paths (required for local CLI agents)
CURSOR_CLI_PATH=cursor
CLAUDE_CODE_PATH=claude

# Preview Stack Ports (optional overrides)
PREVIEW_DB_PORT=5432
PREVIEW_API_PORT=3001
PREVIEW_WEB_PORT=3000
