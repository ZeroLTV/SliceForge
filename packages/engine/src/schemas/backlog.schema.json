{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SliceForgeBacklog",
  "type": "object",
  "properties": {
    "branchName": { "type": "string" },
    "slices": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "passes": { "type": "boolean" },
          "priority": { "type": "integer" },
          "phase": { "type": "integer" },
          "agent": { "type": "string" },
          "acceptance": {
            "type": "array",
            "items": { "type": "string" }
          },
          "docs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "completionArtifacts": {
            "type": "array",
            "items": { "type": "string" }
          },
          "testRequirements": {
            "type": "object",
            "properties": {
              "unit": { "type": "array", "items": { "type": "string" } },
              "integration": { "type": "array", "items": { "type": "string" } },
              "e2e": { "type": "array", "items": { "type": "string" } },
              "acceptanceTags": { "type": "array", "items": { "type": "string" } }
            }
          },
          "description": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["id", "passes", "priority", "description"]
      }
    }
  },
  "required": ["slices"]
}
