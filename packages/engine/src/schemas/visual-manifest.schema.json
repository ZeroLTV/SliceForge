{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SliceForge Visual Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "viewports"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "viewports": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "width",
          "height",
          "screenshot",
          "runtimeErrors",
          "overflow",
          "accessibilityViolations",
          "missingAssets"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "width": { "type": "integer", "minimum": 1, "maximum": 10000 },
          "height": { "type": "integer", "minimum": 1, "maximum": 10000 },
          "screenshot": { "type": "string", "minLength": 1 },
          "runtimeErrors": { "type": "array", "items": { "type": "string" } },
          "overflow": { "type": "array", "items": { "type": "string" } },
          "accessibilityViolations": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "impact", "description"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "impact": { "enum": ["minor", "moderate", "serious", "critical"] },
                "description": { "type": "string", "minLength": 1 }
              }
            }
          },
          "missingAssets": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
