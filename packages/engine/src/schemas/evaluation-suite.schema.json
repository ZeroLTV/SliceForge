{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SliceForge Evaluation Suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "command", "cases"],
  "properties": {
    "name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "command": { "$ref": "#/definitions/command" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "input"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$" },
          "input": {},
          "context": { "type": "array", "maxItems": 1000 },
          "irrelevantContext": { "type": "array", "maxItems": 1000 },
          "repetitions": { "type": "integer", "minimum": 1, "maximum": 100 },
          "allowedPaths": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "protectedPatterns": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "contextVariants": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["original", "reordered", "irrelevant", "reduced"] }
    },
    "agentVersions": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "contextFingerprint": { "type": "string", "minLength": 1 }
  },
  "definitions": {
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "args": { "type": "array", "items": { "type": "string" } },
        "cwd": { "type": "string" },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "env": { "type": "object", "additionalProperties": { "type": "string" } },
        "envAllowlist": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "shell": { "type": "boolean" }
      }
    }
  }
}
