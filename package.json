{
  "name": "sliceforge-workspace",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/engine",
    "lint": "npm run lint -w packages/engine",
    "test": "npm run test -w packages/engine",
    "test:coverage": "npm run test:coverage -w packages/engine",
    "test:soak": "npm run soak:queue -w packages/engine",
    "test:presets": "npm run smoke:presets -w packages/engine"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
