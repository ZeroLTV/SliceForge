{
  "project": "minimal-node-app",
  "agent": {
    "type": "api",
    "model": "claude-3-5-sonnet-20241022"
  },
  "stack": {
    "type": "node"
  },
  "checks": {
    "commands": {
      "build": "npm run build",
      "lint": "npm run lint",
      "test": {
        "unit": "npm run test:unit"
      }
    },
    "forbiddenPatterns": [
      {
        "id": "no-sqlite",
        "pattern": "sqlite3",
        "paths": ["src"],
        "message": "Do not use SQLite. Use PostgreSQL only."
      }
    ]
  },
  "loop": {
    "maxIterations": 5,
    "maxRetriesPerSlice": 2,
    "requireHumanApproval": ["security"],
    "browserTest": {
      "required": false,
      "requirePreviewStack": false
    },
    "testCaseGate": "warn"
  }
}
